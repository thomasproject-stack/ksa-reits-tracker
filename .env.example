# All optional — the pipeline runs with sensible defaults if these are unset.
# No secrets or API keys are required (Yahoo Finance's endpoints are public).

# Ticker code range scanned by discover.py (Saudi REITs live in the 43xx block).
REIT_CODE_MIN=4300
REIT_CODE_MAX=4360

# Snapshot dates compared by extract.py / build_xlsx.py (YYYY-MM-DD).
REIT_START_DATE=2026-04-01
REIT_END_DATE=2026-06-30
